{
  "name": "gestion-etudiants",
  "version": "1.0.0",
  "description": "Application de gestion des étudiants avec Tailwind CSS",
  "main": "index.js",
  "scripts": {
    "build:css": "tailwindcss -i ./styles/input.css -o ./styles/output.css",
    "watch:css": "tailwindcss -i ./styles/input.css -o ./styles/output.css --watch",
    "dev": "npm run watch:css",
    "prod": "npm run build:css"
  },
  "keywords": [
    "students",
    "management",
    "tailwind",
    "css"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "tailwindcss": "^3.3.6",
    "postcss": "^8.4.31",
    "autoprefixer": "^10.4.16"
  }
}